#!/usr/bin/env bash

set -o xtrace
set -o errexit
set -o nounset
set -o pipefail
set -o noclobber

# Runs a "test suite" against a built site

# Build the website to a temporary directory
rm -rf tmp/caiustheory_test/public
mkdir -p tmp/caiustheory_test/public
hugo --gc --minify --cleanDestinationDir --baseURL https://caiustheory.test/ --destination tmp/caiustheory_test/public

# Check it contains the correct things
